---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PdfToJpgConverter from '~/components/PdfToJpgConverter';
import Faq from '~/components/Faq.astro';
---

<BaseLayout
  title="PDF to JPG — PDF pages to images · a → b"
  description="Convert each page of a PDF into a JPG image, free, entirely in your browser. Your file is never uploaded. No accounts, no limits, no ads."
>
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">PDF → JPG</h1>
    <p class="mt-2 text-lg" style="color: var(--color-muted)">
      Render every page of a PDF as a JPG image — entirely in your browser.
    </p>
  </header>

  <PdfToJpgConverter client:load />

  <aside
    class="mt-12 rounded-xl border p-6"
    style="border-color: var(--color-border); background: var(--color-accent-soft)"
  >
    <h2
      class="mb-2 text-xs font-semibold tracking-wider uppercase"
      style="color: var(--color-accent)"
    >
      How this works
    </h2>
    <p class="text-sm leading-relaxed">
      Each page is rendered to a canvas via <code>pdf.js</code>, then exported as a JPG with your
      chosen quality. Useful for sharing single pages as images. Your file never leaves your device.
    </p>
  </aside>

  <Faq
    items={[
      {
        q: 'What do I get back?',
        a: 'One JPG image per page of your PDF, each downloadable separately.',
      },
      {
        q: 'Can I control the image quality?',
        a: 'Yes — a quality slider lets you trade file size against sharpness. 85% is a good default.',
      },
      {
        q: 'Are my files uploaded?',
        a: 'No. Pages are rendered to images in your browser; your PDF never leaves your device.',
      },
    ]}
  />
</BaseLayout>
