---
import ToolLayout from '~/layouts/ToolLayout.astro';
import PdfToJpgConverter from '~/components/PdfToJpgConverter';

const howSteps = [
  { n: '01', title: 'Drop your PDF', body: 'It loads into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Render locally', body: 'Pages are rendered to images by your browser, on your CPU.' },
  { n: '03', title: 'Download the images', body: 'Save each page image back to your machine.' },
];
const faqItems = [
  { q: 'What resolution are the images?', a: 'Pages are rendered at a crisp, screen-friendly resolution — you can tune the quality.' },
  { q: 'How are multiple pages delivered?', a: 'One JPG per page, each downloadable on its own, rendered locally in your browser.' },
  { q: 'Is my PDF uploaded?', a: 'No — rendering happens on your device with zero network requests.' },
];
---

<ToolLayout
  title="PDF to JPG — pages to images in your browser · a → b"
  description="Convert PDF pages to JPG images, free and entirely in your browser. Files are never uploaded. No accounts, no limits, no ads."
  h1="PDF to JPG"
  desc="Save every page of a PDF as a crisp image."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <div style="margin: 22px 0 8px;">
    <PdfToJpgConverter client:load />
  </div>
</ToolLayout>
