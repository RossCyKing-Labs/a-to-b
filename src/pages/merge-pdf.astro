---
import ToolLayout from '~/layouts/ToolLayout.astro';
import MergePdfConverter from '~/components/MergePdfConverter';

const howSteps = [
  { n: '01', title: 'Add your PDFs', body: 'They load into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Order & merge locally', body: 'The work runs in your browser, on your CPU, in memory.' },
  { n: '03', title: 'Download the result', body: 'Save the combined PDF back to your machine.' },
];
const faqItems = [
  { q: 'Can I reorder the files first?', a: 'Yes — arrange them into the order you want before merging.' },
  { q: 'Is there a limit on how many?', a: 'Only your device’s memory. There’s no server cap.' },
  { q: 'Do the files get uploaded?', a: 'No. Merging happens in your browser — nothing leaves your device.' },
];
---

<ToolLayout
  title="Merge PDF — combine PDFs in your browser · a → b"
  description="Merge several PDFs into one, free and entirely in your browser. Reorder before merging. Files are never uploaded. No accounts, no limits, no ads."
  h1="Merge PDFs"
  desc="Combine several PDFs into one, in the order you choose."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <div style="margin: 22px 0 8px;">
    <MergePdfConverter client:load />
  </div>
</ToolLayout>
