---
import BaseLayout from '~/layouts/BaseLayout.astro';

interface Tool {
  title: string;
  formats: string;
  href: string;
}

interface Category {
  title: string;
  description: string;
  tools: Tool[];
}

const categories: Category[] = [
  {
    title: 'Image',
    description: 'Convert between common image formats.',
    tools: [
      { title: 'Image converter', formats: 'PNG · JPEG · WebP', href: '/image' },
    ],
  },
  {
    title: 'PDF tools',
    description: 'Reshape PDFs without ever uploading them.',
    tools: [
      { title: 'Merge PDF', formats: 'Combine into one', href: '/merge-pdf' },
      { title: 'Split PDF', formats: 'One page per file', href: '/split-pdf' },
      { title: 'JPG → PDF', formats: 'Images to PDF', href: '/jpg-to-pdf' },
      { title: 'PDF → JPG', formats: 'Page as image', href: '/pdf-to-jpg' },
      { title: 'Rotate PDF', formats: '90° · 180° · 270°', href: '/rotate-pdf' },
      { title: 'Compress PDF', formats: 'Shrink file size', href: '/compress-pdf' },
    ],
  },
];
---

<BaseLayout title="a → b · privacy-first file converter">
  <section class="py-12 text-center sm:py-16">
    <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-6xl">
      Convert files.
      <span style="color: var(--color-accent)">Privately.</span>
    </h1>
    <p class="mx-auto max-w-xl text-lg sm:text-xl" style="color: var(--color-muted)">
      A free file converter that runs entirely in your browser. Your files never leave your device.
    </p>
  </section>

  {
    categories.map((cat) => (
      <section class="mt-10">
        <div class="mb-4 flex items-baseline justify-between gap-4">
          <h2 class="text-xl font-bold tracking-tight">{cat.title}</h2>
          <p class="text-sm" style="color: var(--color-muted)">
            {cat.description}
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {cat.tools.map((tool) => (
            <a
              href={tool.href}
              class="block rounded-xl border p-5 transition hover:scale-[1.02] hover:shadow-sm"
              style="border-color: var(--color-border)"
            >
              <h3 class="mb-1 font-semibold">{tool.title}</h3>
              <p class="text-sm" style="color: var(--color-muted)">
                {tool.formats}
              </p>
              <p class="mt-3 text-xs font-medium" style="color: var(--color-accent)">
                Open →
              </p>
            </a>
          ))}
        </div>
      </section>
    ))
  }

  <section class="mt-20 grid gap-6 sm:grid-cols-3">
    <div>
      <h3 class="mb-1 font-semibold">100% in your browser</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        Everything runs locally via the Canvas API and WebAssembly. There's no upload endpoint
        on this site — you can verify in DevTools.
      </p>
    </div>
    <div>
      <h3 class="mb-1 font-semibold">No tracking</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        No analytics, no cookies, no third-party scripts, no accounts. Open source on GitHub
        so you can read the code.
      </p>
    </div>
    <div>
      <h3 class="mb-1 font-semibold">Free forever</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        No paywalls. No file-size limits. Optional tip jar if you'd like to support the project.
      </p>
    </div>
  </section>

  <section
    class="mt-16 rounded-xl border p-5 text-sm"
    style="border-color: var(--color-border)"
  >
    <h2 class="mb-2 font-semibold">Why no Word ↔ PDF?</h2>
    <p style="color: var(--color-muted)">
      Microsoft Word and Google Docs both already handle <code>.docx</code> ↔ PDF conversion with
      perfect fidelity, for free. We can't match that quality in the browser without giving up our
      privacy promise. Use Word's <strong>Save As → PDF</strong> or Google Docs's <strong>File →
      Download → PDF</strong> — both work great.
    </p>
  </section>
</BaseLayout>
