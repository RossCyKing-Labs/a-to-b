---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Faq from '~/components/Faq.astro';

interface Tool {
  title: string;
  formats: string;
  href: string;
}

interface Category {
  title: string;
  description: string;
  tools: Tool[];
}

// Compress PDF is the hero — it's what most people come here for (shrinking a
// PDF to fit an upload limit). Every other tool is listed below as an extra.
const otherCategories: Category[] = [
  {
    title: 'Image',
    description: 'Convert between common image formats.',
    tools: [
      { title: 'Image converter', formats: 'PNG · JPEG · WebP', href: '/image' },
    ],
  },
  {
    title: 'More PDF tools',
    description: 'Reshape PDFs without ever uploading them.',
    tools: [
      { title: 'Merge PDF', formats: 'Combine into one', href: '/merge-pdf' },
      { title: 'Split PDF', formats: 'One page per file', href: '/split-pdf' },
      { title: 'JPG → PDF', formats: 'Images to PDF', href: '/jpg-to-pdf' },
      { title: 'PDF → JPG', formats: 'Page as image', href: '/pdf-to-jpg' },
      { title: 'Rotate PDF', formats: '90° · 180° · 270°', href: '/rotate-pdf' },
    ],
  },
];
---

<BaseLayout
  title="Compress PDF free in your browser · a → b"
  description="Make a PDF smaller to fit upload limits — free, in your browser, no uploads, no tracking, no ads. Plus merge, split, rotate PDFs and convert PNG, JPEG, and WebP."
>
  <section class="py-10 text-center sm:py-12">
    <h1 class="mb-3 text-4xl font-bold tracking-tight sm:text-5xl">
      Make your PDF
      <span style="color: var(--color-accent)">smaller.</span>
    </h1>
    <p class="mx-auto max-w-xl text-lg" style="color: var(--color-muted)">
      Shrink a PDF so it fits an upload limit — job applications, forms, and email
      attachments that only accept small files. It all happens in your browser; your file
      never leaves your device.
    </p>
  </section>

  <!-- Hero: the PDF compressor, the tool most people are here for. -->
  <section class="mb-6">
    <a
      href="/compress-pdf"
      class="block rounded-2xl border-2 p-8 transition hover:scale-[1.01] hover:shadow-md sm:p-10"
      style="border-color: var(--color-accent); background: var(--color-accent-soft)"
    >
      <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Compress PDF</h2>
          <p class="mt-2 max-w-lg text-base" style="color: var(--color-muted)">
            Reduce a PDF's file size — great for getting under a 2&nbsp;MB (or smaller)
            upload limit. Text stays selectable, and you choose how hard to compress.
          </p>
        </div>
        <span
          class="shrink-0 rounded-lg px-5 py-3 text-sm font-semibold text-white"
          style="background: var(--color-accent)"
        >
          Compress a PDF →
        </span>
      </div>
    </a>
  </section>

  <section class="mt-14">
    <div class="mb-4">
      <h2 class="text-xl font-bold tracking-tight">More tools</h2>
      <p class="text-sm" style="color: var(--color-muted)">
        Other free, in-browser converters — same privacy promise, no uploads.
      </p>
    </div>
    {
      otherCategories.map((cat) => (
        <div class="mt-6">
          <div class="mb-3 flex items-baseline justify-between gap-4">
            <h3 class="text-sm font-semibold tracking-wide uppercase" style="color: var(--color-muted)">
              {cat.title}
            </h3>
            <p class="text-sm" style="color: var(--color-muted)">
              {cat.description}
            </p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {cat.tools.map((tool) => (
              <a
                href={tool.href}
                class="block rounded-xl border p-5 transition hover:scale-[1.02] hover:shadow-sm"
                style="border-color: var(--color-border)"
              >
                <h4 class="mb-1 font-semibold">{tool.title}</h4>
                <p class="text-sm" style="color: var(--color-muted)">
                  {tool.formats}
                </p>
                <p class="mt-3 text-xs font-medium" style="color: var(--color-accent)">
                  Open →
                </p>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <section class="mt-20 grid gap-6 sm:grid-cols-3">
    <div>
      <h3 class="mb-1 font-semibold">100% in your browser</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        Everything runs locally via the Canvas API and WebAssembly. There's no upload endpoint
        on this site — you can verify in DevTools.
      </p>
    </div>
    <div>
      <h3 class="mb-1 font-semibold">No tracking</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        No analytics, no cookies, no third-party scripts, no accounts. Open source on GitHub
        so you can read the code.
      </p>
    </div>
    <div>
      <h3 class="mb-1 font-semibold">Free forever</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        No paywalls. No file-size limits. Optional tip jar if you'd like to support the project.
      </p>
    </div>
  </section>

  <section
    class="mt-16 rounded-xl border p-5 text-sm"
    style="border-color: var(--color-border)"
  >
    <h2 class="mb-2 font-semibold">Why no Word ↔ PDF?</h2>
    <p style="color: var(--color-muted)">
      Microsoft Word and Google Docs both already handle <code>.docx</code> ↔ PDF conversion with
      perfect fidelity, for free. We can't match that quality in the browser without giving up our
      privacy promise. Use Word's <strong>Save As → PDF</strong> or Google Docs's <strong>File →
      Download → PDF</strong> — both work great.
    </p>
  </section>

  <Faq
    items={[
      {
        q: 'Is a → b really free?',
        a: 'Yes — completely free, with no paywalls, no file-size limits, and no accounts. The only optional extra is a tip jar if you want to support the project.',
      },
      {
        q: 'Are my files uploaded to a server?',
        a: 'No. Every conversion runs inside your own browser. There is no upload endpoint at all — you can confirm it in your browser’s DevTools Network tab while a conversion runs.',
      },
      {
        q: 'Do I need to install anything or create an account?',
        a: 'No. a → b runs as a normal website — nothing to install, no sign-up. Once you’ve visited once it even works offline.',
      },
      {
        q: 'Which conversions are supported?',
        a: 'Image conversion between PNG, JPEG, and WebP, plus PDF tools: merge, split, rotate, compress, JPG → PDF, and PDF → JPG.',
      },
    ]}
  />
</BaseLayout>
