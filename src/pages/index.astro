---
import BaseLayout from '~/layouts/BaseLayout.astro';

interface Tool {
  title: string;
  formats: string;
  href: string;
}

interface Category {
  title: string;
  description: string;
  tools: Tool[];
}

const categories: Category[] = [
  {
    title: 'Image',
    description: 'Convert between common image formats.',
    tools: [
      { title: 'Image converter', formats: 'PNG · JPEG · WebP', href: '/image' },
    ],
  },
  {
    title: 'Document',
    description: 'Word to PDF with formatting preserved.',
    tools: [
      { title: 'Word → PDF', formats: '.docx → .pdf', href: '/word-to-pdf' },
    ],
  },
  {
    title: 'PDF tools',
    description: 'Reshape PDFs without ever uploading them.',
    tools: [
      { title: 'Compress PDF', formats: 'Shrink file size', href: '/compress-pdf' },
    ],
  },
];
---

<BaseLayout title="a → b · privacy-first file converter">
  <section class="py-12 text-center sm:py-16">
    <h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-6xl">
      Convert files.
      <span style="color: var(--color-accent)">Privately.</span>
    </h1>
    <p class="mx-auto max-w-xl text-lg sm:text-xl" style="color: var(--color-muted)">
      A free file converter that runs entirely in your browser. Your files never leave your device.
    </p>
  </section>

  {
    categories.map((cat) => (
      <section class="mt-10">
        <div class="mb-4 flex items-baseline justify-between gap-4">
          <h2 class="text-xl font-bold tracking-tight">{cat.title}</h2>
          <p class="text-sm" style="color: var(--color-muted)">
            {cat.description}
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {cat.tools.map((tool) => (
            <a
              href={tool.href}
              class="block rounded-xl border p-5 transition hover:scale-[1.02] hover:shadow-sm"
              style="border-color: var(--color-border)"
            >
              <h3 class="mb-1 font-semibold">{tool.title}</h3>
              <p class="text-sm" style="color: var(--color-muted)">
                {tool.formats}
              </p>
              <p class="mt-3 text-xs font-medium" style="color: var(--color-accent)">
                Open →
              </p>
            </a>
          ))}
        </div>
      </section>
    ))
  }

  <section class="mt-20 grid gap-6 sm:grid-cols-3">
    <div>
      <h3 class="mb-1 font-semibold">100% in your browser</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        Conversion runs locally via your browser's built-in tools. There's no upload endpoint.
      </p>
    </div>
    <div>
      <h3 class="mb-1 font-semibold">No tracking</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        No analytics, no cookies, no third-party scripts. You can verify in DevTools.
      </p>
    </div>
    <div>
      <h3 class="mb-1 font-semibold">Free forever</h3>
      <p class="text-sm" style="color: var(--color-muted)">
        No paywalls. No file-size limits. Tip jar if you'd like to support the project.
      </p>
    </div>
  </section>

  <section class="mt-16 rounded-xl border p-5 text-sm" style="border-color: var(--color-border)">
    <h2 class="mb-2 font-semibold">More tools coming back soon</h2>
    <p style="color: var(--color-muted)">
      We're temporarily focused on perfecting Word → PDF before we bring back Merge, Split,
      Rotate, JPG ↔ PDF, and PDF → Word. Bookmark
      <a href="https://github.com/rosscyking1115/a-to-b" class="underline hover:no-underline" rel="noopener">the repo</a>
      to follow progress.
    </p>
  </section>
</BaseLayout>
