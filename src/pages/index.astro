---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Faq from '~/components/Faq.astro';

// Every tool except Compress (which is the featured hero card).
const gridTools = [
  { label: 'Convert image', href: '/image', blurb: 'Change between JPG, PNG and WebP.' },
  { label: 'Merge PDFs', href: '/merge-pdf', blurb: 'Combine several PDFs into one.' },
  { label: 'Split PDF', href: '/split-pdf', blurb: 'Pull out the pages you need.' },
  { label: 'JPG → PDF', href: '/jpg-to-pdf', blurb: 'Turn photos into one document.' },
  { label: 'PDF → JPG', href: '/pdf-to-jpg', blurb: 'Save every page as an image.' },
  { label: 'Rotate PDF', href: '/rotate-pdf', blurb: 'Fix sideways scans.' },
];

const faqItems = [
  {
    q: 'Is it really private?',
    a: 'Yes. Files are processed in your browser with WebAssembly — open DevTools → Network and you’ll see zero uploads during a conversion.',
  },
  {
    q: 'Is there a file-size limit?',
    a: 'Only your device’s memory. There’s no server-side cap because there is no server doing the work.',
  },
  {
    q: 'Do I need an account?',
    a: 'No accounts, no sign-in, no email. Drop a file and go.',
  },
  {
    q: 'What does it cost?',
    a: 'It’s free. If it saved you time, you can leave a small tip on <a href="https://ko-fi.com/rosscyking" rel="noopener">Ko-fi</a> — entirely optional.',
  },
];
---

<BaseLayout
  title="Compress PDF free in your browser · a → b"
  description="Make a PDF smaller to fit upload limits — free, in your browser, no uploads, no tracking, no ads. Plus merge, split, rotate PDFs and convert PNG, JPEG, and WebP."
>
  <section class="hero">
    <div class="eyebrow">
      <span class="dot"></span>In-browser &middot; Private
    </div>
    <h1>Make your PDF <span class="accent">smaller.</span></h1>
    <p class="lede">
      Shrink a PDF to fit an upload limit — job applications, forms, email attachments. It all
      happens in your browser; your file never leaves your device.
    </p>
  </section>

  <!-- Featured: the compressor, the tool most people are here for. -->
  <a class="featured nudge" href="/compress-pdf">
    <div class="featured-text">
      <div class="featured-title">Compress PDF</div>
      <div class="featured-body">
        Reduce a PDF’s file size — great for getting under a 2 MB (or smaller) upload limit. Text
        stays selectable, and you choose how hard to compress.
      </div>
    </div>
    <span class="featured-cta">Compress a PDF <span class="nudge-arrow">&#8594;</span></span>
  </a>

  <div class="trust">
    <div class="trust-card">
      <div class="trust-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2M5 5h14v14H5zM9 9h6v6H9z"></path></svg>
      </div>
      <div class="trust-title">In your browser</div>
      <div class="trust-body">Files are processed locally with WebAssembly. Nothing is ever uploaded.</div>
    </div>
    <div class="trust-card">
      <div class="trust-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9.9 4.2A9.5 9.5 0 0 1 12 4c5 0 9 5 9 8a12 12 0 0 1-2 2.8M6.6 6.6C3.9 8.2 2 10.8 2 12c0 2 4 8 10 8a9 9 0 0 0 3.4-.7M3 3l18 18"></path></svg>
      </div>
      <div class="trust-title">No tracking</div>
      <div class="trust-body">No analytics, no cookies, no third-party scripts. You are not the product.</div>
    </div>
    <div class="trust-card">
      <div class="trust-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path></svg>
      </div>
      <div class="trust-title">Free &amp; open</div>
      <div class="trust-body">No account, no limits, no ads. Just tools that run on your machine.</div>
    </div>
  </div>

  <section class="tools" data-tools>
    <div class="eyebrow-plain">More tools</div>
    <div class="tool-grid">
      {
        gridTools.map((tool, i) => (
          <a class="tool-card nudge" href={tool.href} data-reveal style={`--i:${i}`}>
            <div class="tool-name">{tool.label}</div>
            <div class="tool-blurb">{tool.blurb}</div>
            <div class="tool-open">
              Open<span class="nudge-arrow">&#8594;</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <div class="note">
    <strong>Why no Word &harr; PDF?</strong> True Word editing needs a rendering engine we’d have to
    run on a server — which would break the promise that your files never leave your device. So we
    only ship tools that run fully in your browser.
  </div>

  <Faq items={faqItems} />
</BaseLayout>

<style>
  .hero {
    padding: 44px 0 6px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
  }
  .hero h1 {
    font-size: 34px;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 12px 0 8px;
    color: var(--ink);
    font-weight: 600;
  }
  .accent {
    color: var(--accent);
  }
  .lede {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .featured {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin: 22px 0 8px;
    padding: 22px;
    border-radius: 16px;
    background: var(--accent-wash);
    border: 1px solid rgba(249, 115, 22, 0.45);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    text-decoration: none;
  }
  .featured-text {
    flex: 1;
    min-width: 260px;
  }
  .featured-title {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .featured-body {
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 48ch;
  }
  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #ffffff;
    border-radius: 12px;
    padding: 13px 22px;
    font-size: 15px;
    font-weight: 600;
    box-shadow: 0 2px 10px rgba(249, 115, 22, 0.28);
    white-space: nowrap;
  }

  .trust {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
    margin-top: 40px;
  }
  .trust-card {
    border: 1px solid var(--hair);
    border-radius: 14px;
    padding: 18px;
    background: var(--card);
  }
  .trust-icon {
    color: var(--accent);
    margin-bottom: 10px;
  }
  .trust-title {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .trust-body {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.45;
  }

  .tools {
    margin-top: 44px;
  }
  .eyebrow-plain {
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .tool-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    min-height: 118px;
    background: var(--card);
    box-sizing: border-box;
    text-decoration: none;
    border: 1px solid var(--hair);
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
    transition:
      transform 160ms var(--ease-out-quad),
      border-color 160ms,
      box-shadow 160ms;
  }
  .tool-card:hover {
    transform: translateY(-2px);
    border-color: var(--hair-3);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
  .tool-card:active {
    transform: translateY(0) scale(0.99);
  }
  .tool-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
  }
  .tool-blurb {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.4;
    margin-top: 6px;
    flex: 1;
  }
  .tool-open {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 14px;
  }

  /* Grid stagger reveal (added by script; no-JS shows cards immediately). */
  .tool-card.pre-reveal {
    opacity: 0;
  }
  .tool-card.revealed {
    animation: rise 340ms var(--ease-out-quad) both;
    animation-delay: calc(var(--i) * 60ms);
  }

  .note {
    margin-top: 40px;
    padding: 16px 18px;
    background: var(--field);
    border-radius: 12px;
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .note strong {
    color: var(--ink);
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .hero h1 {
      font-size: 27px;
    }
    .trust,
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Staggered reveal of the tool grid when it scrolls into view. Cards are only
  // hidden once we know JS + IntersectionObserver are available, so no-JS users
  // still see them.
  const cards = Array.from(document.querySelectorAll('.tool-card'));
  const section = document.querySelector('[data-tools]');
  if (cards.length && section && 'IntersectionObserver' in window) {
    cards.forEach((c) => c.classList.add('pre-reveal'));
    const reveal = () => cards.forEach((c) => c.classList.replace('pre-reveal', 'revealed'));
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          reveal();
          io.disconnect();
        }
      },
      { threshold: 0.1 },
    );
    io.observe(section);
    // Safety: reveal after a moment even if the observer never fires.
    setTimeout(reveal, 1600);
  }
</script>
