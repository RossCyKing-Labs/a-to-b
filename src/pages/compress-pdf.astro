---
import ToolLayout from '~/layouts/ToolLayout.astro';
import CompressPdfConverter from '~/components/CompressPdfConverter';

const howSteps = [
  { n: '01', title: 'Drop your file', body: 'It loads into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Compress locally', body: 'The work runs in your browser, on your CPU, in memory.' },
  { n: '03', title: 'Download the result', body: 'Save it back to your machine. We never see the file.' },
];

const faqItems = [
  {
    q: 'Will compressing blur my text?',
    a: 'No. Text stays sharp and selectable — only images are re-encoded to hit your target size. (The Strong level flattens pages to images but keeps an invisible, still-selectable text layer.)',
  },
  {
    q: 'Can I choose the exact final size?',
    a: 'Pick a size target (like “under 2 MB”) or a quality level. In size mode we aim just under your limit.',
  },
  {
    q: 'Are my PDFs uploaded to compress them?',
    a: 'Never. Compression runs entirely on your device — verify it in DevTools → Network.',
  },
];
---

<ToolLayout
  title="Compress PDF — shrink file size in-browser · a → b"
  description="Compress and shrink PDF file size, free, entirely in your browser. Text stays selectable. Files are never uploaded. No accounts, no limits, no ads."
  h1="Compress PDF"
  desc="Make your PDF smaller to fit an upload limit — processed right here, on your device."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <CompressPdfConverter client:load />
</ToolLayout>
