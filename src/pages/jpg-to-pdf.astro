---
import ToolLayout from '~/layouts/ToolLayout.astro';
import JpgToPdfConverter from '~/components/JpgToPdfConverter';

const howSteps = [
  { n: '01', title: 'Add your images', body: 'They load into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Build the PDF locally', body: 'The work runs in your browser, on your CPU, in memory.' },
  { n: '03', title: 'Download the result', body: 'Save the PDF back to your machine. We never see it.' },
];
const faqItems = [
  { q: 'Can I combine many photos?', a: 'Yes — select several images and they become pages in one PDF, in the order you choose.' },
  { q: 'Will the images be compressed?', a: 'Only lightly, to keep the PDF a reasonable size. You stay in control.' },
  { q: 'Do my images leave the device?', a: 'No — the PDF is built in your browser and never uploaded.' },
];
---

<ToolLayout
  title="JPG to PDF — images to PDF in your browser · a → b"
  description="Turn JPG and PNG images into a single PDF, free and entirely in your browser. Files are never uploaded. No accounts, no limits, no ads."
  h1="JPG to PDF"
  desc="Turn photos into one shareable PDF."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <div style="margin: 22px 0 8px;">
    <JpgToPdfConverter client:load />
  </div>
</ToolLayout>
