---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found · a → b" description="That page doesn't exist on a → b.">
  <div class="nf">
    <div class="glyph">a<span class="arrow">&#8594;</span><span class="q">?</span></div>
    <div class="title">This page went nowhere.</div>
    <p class="body">
      Which is fitting, since nothing here leaves your device either. Let’s get you back to the
      tools.
    </p>
    <a class="cta nudge" href="/">Back to tools <span class="nudge-arrow">&#8594;</span></a>
  </div>
</BaseLayout>

<style>
  .nf {
    padding: 80px 0;
    text-align: center;
  }
  .glyph {
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .glyph .arrow {
    color: var(--accent);
    padding: 0 10px;
  }
  .glyph .q {
    color: var(--faint);
  }
  .title {
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    margin: 22px 0 8px;
  }
  .body {
    font-size: 15px;
    color: var(--muted);
    margin: 0 auto 26px;
    max-width: 42ch;
    line-height: 1.5;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    border-radius: 12px;
    padding: 12px 20px;
    font-size: 14.5px;
    font-weight: 600;
  }
</style>
