---
import ToolLayout from '~/layouts/ToolLayout.astro';
import SplitPdfConverter from '~/components/SplitPdfConverter';

const howSteps = [
  { n: '01', title: 'Drop your PDF', body: 'It loads into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Split locally', body: 'The work runs in your browser, on your CPU, in memory.' },
  { n: '03', title: 'Download the pages', body: 'Save each page back to your machine. We never see the file.' },
];
const faqItems = [
  { q: 'What do I get back?', a: 'One PDF per page, each downloadable on its own. Nothing is re-compressed — pages are copied as-is.' },
  { q: 'Does splitting reduce quality?', a: 'No — the selected pages are copied into new PDFs exactly as they were.' },
  { q: 'Are my PDFs uploaded?', a: 'Never. Splitting runs fully on your device.' },
];
---

<ToolLayout
  title="Split PDF — extract pages in your browser · a → b"
  description="Split a PDF into single pages, free and entirely in your browser. Files are never uploaded. No accounts, no limits, no ads."
  h1="Split a PDF"
  desc="Break a PDF into one downloadable file per page."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <div style="margin: 22px 0 8px;">
    <SplitPdfConverter client:load />
  </div>
</ToolLayout>
