---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PdfToWordConverter from '~/components/PdfToWordConverter';
---

<BaseLayout
  title="PDF to Word · a → b"
  description="Convert PDF files to editable Word documents in your browser. Files never leave your device."
>
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">PDF → Word</h1>
    <p class="mt-2 text-lg" style="color: var(--color-muted)">
      Convert PDFs to editable <code>.docx</code> documents — entirely in your browser.
    </p>
  </header>

  <PdfToWordConverter client:load />

  <aside
    class="mt-12 space-y-6 rounded-xl border p-6"
    style="border-color: var(--color-border); background: var(--color-accent-soft)"
  >
    <div>
      <h2
        class="mb-2 text-xs font-semibold tracking-wider uppercase"
        style="color: var(--color-accent)"
      >
        How this works
      </h2>
      <p class="text-sm leading-relaxed">
        We read your PDF locally using <code>pdf.js</code>, extract text along with its position,
        font size, and styling (<strong>bold, italic, hyperlinks</strong>), reconstruct paragraphs
        and headings, then write a new <code>.docx</code> file using the <code>docx</code> library.
      </p>
    </div>

    <div>
      <h2
        class="mb-2 text-xs font-semibold tracking-wider uppercase"
        style="color: var(--color-accent)"
      >
        Best for
      </h2>
      <ul
        class="ml-5 list-disc space-y-1 text-sm leading-relaxed"
        style="color: var(--color-muted)"
      >
        <li>Text-heavy single-column PDFs (memos, reports, articles, CVs, contracts)</li>
        <li>PDFs originally created from Word or another text-based source</li>
        <li>Documents with hyperlinks — links are preserved in the Word output</li>
      </ul>
    </div>

    <div>
      <h2
        class="mb-2 text-xs font-semibold tracking-wider uppercase"
        style="color: var(--color-accent)"
      >
        What may not round-trip well
      </h2>
      <ul
        class="ml-5 list-disc space-y-1 text-sm leading-relaxed"
        style="color: var(--color-muted)"
      >
        <li><strong>Scanned PDFs</strong> — images of text, not text. OCR coming in a later release.</li>
        <li><strong>Multi-column layouts</strong> — adjacent columns may interleave</li>
        <li><strong>Tables</strong> — flattened to plain paragraphs in v1</li>
        <li><strong>Images and charts</strong> — text extracted, visuals dropped in v1</li>
        <li><strong>Exact fonts</strong> — output uses Word's default styles</li>
        <li><strong>Password-protected PDFs</strong> — remove the password first</li>
      </ul>
    </div>
  </aside>
</BaseLayout>
