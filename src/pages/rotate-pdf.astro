---
import ToolLayout from '~/layouts/ToolLayout.astro';
import RotatePdfConverter from '~/components/RotatePdfConverter';

const howSteps = [
  { n: '01', title: 'Drop your PDF', body: 'It loads into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Rotate locally', body: 'The work runs in your browser, on your CPU, in memory.' },
  { n: '03', title: 'Download the result', body: 'Save the rotated PDF back to your machine.' },
];
const faqItems = [
  { q: 'Which way can I rotate?', a: '90° right, 90° left, or 180° — applied to every page of the document.' },
  { q: 'Does rotating reduce quality?', a: 'No — rotation is lossless; page content is untouched.' },
  { q: 'Are my files uploaded?', a: 'Never. Rotation runs entirely in your browser.' },
];
---

<ToolLayout
  title="Rotate PDF — fix orientation in your browser · a → b"
  description="Rotate PDF pages 90° or 180°, free and entirely in your browser. Files are never uploaded. No accounts, no limits, no ads."
  h1="Rotate a PDF"
  desc="Fix sideways scans and set the right orientation."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <div style="margin: 22px 0 8px;">
    <RotatePdfConverter client:load />
  </div>
</ToolLayout>
