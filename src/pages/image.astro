---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ImageConverter from '~/components/ImageConverter';

const howSteps = [
  { n: '01', title: 'Drop your images', body: 'They load into this page. Nothing is uploaded to a server.' },
  { n: '02', title: 'Convert locally', body: 'Pixels are re-encoded by your browser, on your CPU.' },
  { n: '03', title: 'Download the result', body: 'Save it back to your machine. We never see the file.' },
];
const faqItems = [
  { q: 'Which formats are supported?', a: 'Convert freely between JPG, PNG and WebP. Everything is re-encoded locally in your browser.' },
  { q: 'Does converting lose quality?', a: 'Only if you target a lossy format like JPG. PNG and WebP (lossless) preserve every pixel.' },
  { q: 'Are my photos uploaded?', a: 'No — pixels are read into memory and re-encoded on your CPU. Nothing is sent anywhere.' },
];
---

<ToolLayout
  title="Image converter — PNG, JPEG & WebP · a → b"
  description="Free image converter for PNG, JPEG, and WebP. Runs entirely in your browser — your files are never uploaded. No accounts, no limits, no ads."
  h1="Convert an image"
  desc="Change an image between JPG, PNG and WebP — nothing leaves your browser."
  howSteps={howSteps}
  faqItems={faqItems}
>
  <div style="margin: 22px 0 8px;">
    <ImageConverter client:load />
  </div>
</ToolLayout>
