---
import BaseLayout from './BaseLayout.astro';
import Faq from '~/components/Faq.astro';

interface HowStep {
  n: string;
  title: string;
  body: string;
}
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description?: string;
  h1: string;
  desc: string;
  howSteps: HowStep[];
  faqItems: FaqItem[];
}

const { title, description, h1, desc, howSteps, faqItems } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="tool-head">
    <a class="back" href="/">&#8592; All tools</a>
    <h1>{h1}</h1>
    <p class="tool-desc">{desc}</p>
  </div>

  <slot />

  <section class="how">
    <div class="how-eyebrow">How this works</div>
    <div class="how-grid">
      {
        howSteps.map((s) => (
          <div class="how-card">
            <div class="how-n">{s.n}</div>
            <div class="how-title">{s.title}</div>
            <div class="how-body">{s.body}</div>
          </div>
        ))
      }
    </div>
  </section>

  <Faq items={faqItems} />
</BaseLayout>

<style>
  .tool-head {
    padding: 44px 0 6px;
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 14px;
  }
  .back:hover {
    color: var(--ink);
  }
  .tool-head h1 {
    font-size: 34px;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 4px 0 8px;
    color: var(--ink);
    font-weight: 600;
  }
  .tool-desc {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 54ch;
  }

  .how {
    margin-top: 44px;
  }
  .how-eyebrow {
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 18px;
  }
  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  .how-card {
    border: 1px solid var(--hair);
    border-radius: 12px;
    padding: 16px;
    background: var(--card);
  }
  .how-n {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .how-title {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .how-body {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.45;
  }

  @media (max-width: 720px) {
    .tool-head h1 {
      font-size: 27px;
    }
    .how-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
