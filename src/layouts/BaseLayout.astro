---
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'A free, privacy-first file converter that runs entirely in your browser. Files never leave your device.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.png', Astro.site).href;

// The tool set — used by the header dropdown and the footer.
const tools = [
  { label: 'Compress PDF', href: '/compress-pdf', blurb: 'Shrink a PDF to fit a limit' },
  { label: 'Convert image', href: '/image', blurb: 'JPG · PNG · WebP' },
  { label: 'Merge PDFs', href: '/merge-pdf', blurb: 'Several files → one' },
  { label: 'Split PDF', href: '/split-pdf', blurb: 'Pull out the pages you need' },
  { label: 'JPG → PDF', href: '/jpg-to-pdf', blurb: 'Photos into one document' },
  { label: 'PDF → JPG', href: '/pdf-to-jpg', blurb: 'Every page as an image' },
  { label: 'Rotate PDF', href: '/rotate-pdf', blurb: 'Fix sideways scans' },
];

const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isTool = tools.some((t) => t.href === path);
const cls = {
  compress: path === '/compress-pdf' ? 'navlink-active' : '',
  tools: isTool && path !== '/compress-pdf' ? 'navlink-active' : '',
  about: path === '/about' ? 'navlink-active' : '',
  privacy: path === '/privacy' ? 'navlink-active' : '',
};
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Set the theme before first paint (no flash): saved choice or OS preference.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t =
              window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          }
          document.documentElement.dataset.theme = t;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f97316" />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="a → b" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- Service worker registration. Skipped on localhost (see register-sw.js). -->
    <script src="/register-sw.js" defer></script>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="site-header">
      <div class="bar">
        <a class="wordmark" href="/" aria-label="a to b — home"
          >a<span class="arrow">&#8594;</span>b</a
        >

        <nav class="nav-desktop" aria-label="Primary">
          <a class={`navlink ${cls.compress}`} href="/compress-pdf">Compress</a>

          <div class="dropdown" data-dropdown>
            <button type="button" class={`navlink ${cls.tools}`} data-dd-toggle aria-expanded="false" aria-haspopup="true">
              Tools <span class="chev" aria-hidden="true">&#9662;</span>
            </button>
            <div class="dd-menu" role="menu">
              {
                tools.map((t) => (
                  <a class="dditem" href={t.href} role="menuitem">
                    <span>{t.label}</span>
                    <span class="dd-blurb">{t.blurb}</span>
                  </a>
                ))
              }
            </div>
          </div>

          <a class={`navlink ${cls.about}`} href="/about">About</a>
          <a class={`navlink ${cls.privacy}`} href="/privacy">Privacy</a>

          <button type="button" class="themebtn" data-toggle-theme aria-label="Toggle dark mode">
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
            <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
          </button>
        </nav>

        <button type="button" class="hamburger" data-menu-toggle aria-label="Menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
        </button>
      </div>

      <div class="mobile-menu" data-mobile-menu hidden>
        <div class="mm-head">
          <span class="eyebrow">Menu</span>
          <button type="button" class="themebtn" data-toggle-theme aria-label="Toggle dark mode">
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
            <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
          </button>
        </div>
        {
          tools.map((t) => (
            <a class={`mm-link ${path === t.href ? 'mm-active' : ''}`} href={t.href}>
              {t.label}
            </a>
          ))
        }
        <a class={`mm-link ${cls.about ? 'mm-active' : ''}`} href="/about">About</a>
        <a class={`mm-link ${cls.privacy ? 'mm-active' : ''}`} href="/privacy">Privacy</a>
      </div>
    </header>

    <main class="site-main page-enter">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="foot-inner">
        <div class="foot-top">
          <span class="foot-wordmark">a<span class="arrow">&#8594;</span>b</span>
          <span class="foot-tag">No uploads. No tracking. No ads.</span>
        </div>
        <div class="foot-cols">
          <div>
            <div class="foot-h">Tools</div>
            <div class="foot-tools">
              {tools.map((t) => <a href={t.href}>{t.label}</a>)}
            </div>
          </div>
          <div>
            <div class="foot-h">Product</div>
            <div class="foot-list">
              <a href="/about">About</a>
              <a href="/privacy">Privacy</a>
            </div>
          </div>
          <div>
            <div class="foot-h">Support</div>
            <div class="foot-list">
              <a href="https://ko-fi.com/rosscyking" target="_blank" rel="noopener">Ko-fi</a>
              <a href="https://github.com/rosscyking1115/a-to-b" rel="noopener">Source code</a>
            </div>
          </div>
        </div>
        <div class="foot-bottom">
          <span>&copy; {new Date().getFullYear()} a &rarr; b</span>
          <span>Runs entirely in your browser.</span>
        </div>
      </div>
    </footer>

    <script>
      // Theme toggle (persist choice), Tools dropdown, and mobile menu.
      const root = document.documentElement;
      document.querySelectorAll('[data-toggle-theme]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
          root.dataset.theme = next;
          try {
            localStorage.setItem('theme', next);
          } catch {
            /* ignore */
          }
        });
      });

      const dd = document.querySelector('[data-dropdown]');
      const ddToggle = dd?.querySelector('[data-dd-toggle]');
      const closeDd = () => {
        dd?.classList.remove('open');
        ddToggle?.setAttribute('aria-expanded', 'false');
      };
      ddToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = dd?.classList.toggle('open');
        ddToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', (e) => {
        if (dd && !dd.contains(e.target as Node)) closeDd();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeDd();
      });

      const menu = document.querySelector('[data-mobile-menu]');
      const menuToggle = document.querySelector('[data-menu-toggle]');
      menuToggle?.addEventListener('click', () => {
        const willOpen = menu?.hasAttribute('hidden');
        if (willOpen) menu?.removeAttribute('hidden');
        else menu?.setAttribute('hidden', '');
        menuToggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      });
    </script>

    <style>
      /* ---- Shared ---- */
      .arrow {
        color: var(--accent);
        display: inline-block;
        padding: 0 5px;
        transition: transform 200ms var(--ease-out-quad);
      }
      .site-main {
        flex: 1;
        width: 100%;
        max-width: 880px;
        margin: 0 auto;
        padding: 0 24px;
        box-sizing: border-box;
      }
      .page-enter {
        animation: rise 300ms var(--ease-out-quad) both;
      }

      /* ---- Header ---- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--paper-85);
        backdrop-filter: saturate(1.5) blur(10px);
        -webkit-backdrop-filter: saturate(1.5) blur(10px);
        border-bottom: 1px solid var(--hair);
      }
      .bar {
        max-width: 880px;
        margin: 0 auto;
        padding: 0 24px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .wordmark {
        font-size: 19px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--ink);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
      }
      .wordmark:hover .arrow {
        transform: translateX(4px);
      }
      .nav-desktop {
        display: flex;
        align-items: center;
        gap: 24px;
        font-size: 14px;
      }
      .navlink {
        position: relative;
        color: var(--ink);
        font-weight: 500;
        text-decoration: none;
        background: none;
        border: none;
        padding: 0;
        font: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }
      .navlink::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -6px;
        height: 1.5px;
        background: var(--ink);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 160ms var(--ease-out-quad);
      }
      .navlink:hover::after {
        transform: scaleX(1);
      }
      .navlink-active::after {
        transform: scaleX(1);
        background: var(--accent);
        height: 2px;
      }
      .chev {
        font-size: 9px;
        transition: transform 200ms var(--ease-out-quad);
      }
      .dropdown.open .chev {
        transform: rotate(180deg);
      }
      .dropdown {
        position: relative;
      }
      .dd-menu {
        position: absolute;
        top: 34px;
        right: 0;
        width: 240px;
        background: var(--card);
        border: 1px solid var(--hair);
        border-radius: 12px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.14);
        padding: 6px;
        display: none;
      }
      .dropdown.open .dd-menu {
        display: block;
        animation: rise 160ms var(--ease-out-quad) both;
      }
      .dditem {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 9px 11px;
        border-radius: 8px;
        text-decoration: none;
        color: var(--ink);
        font-size: 13.5px;
        font-weight: 500;
      }
      .dditem:hover {
        background: var(--field);
      }
      .dd-blurb {
        color: var(--faint);
        font-size: 12px;
        text-align: right;
      }
      .themebtn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition:
          background 160ms,
          color 160ms;
      }
      .themebtn:hover {
        background: var(--field);
        color: var(--ink);
      }
      .icon-sun {
        display: none;
      }
      [data-theme='dark'] .icon-sun {
        display: inline-flex;
      }
      [data-theme='dark'] .icon-moon {
        display: none;
      }
      .hamburger {
        display: none;
        width: 38px;
        height: 38px;
        align-items: center;
        justify-content: center;
        border: none;
        background: transparent;
        color: var(--ink);
        cursor: pointer;
        border-radius: 8px;
      }

      /* ---- Mobile menu ---- */
      .mobile-menu {
        border-top: 1px solid var(--hair);
        background: var(--paper);
        padding: 10px 24px 18px;
        animation: rise 180ms var(--ease-out-quad) both;
      }
      .mm-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 2px 6px;
      }
      .eyebrow {
        font-size: 11.5px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .mm-link {
        display: block;
        padding: 11px 2px;
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        color: var(--ink);
        border-bottom: 1px solid var(--hair);
      }
      .mm-active {
        color: var(--accent);
      }

      /* ---- Footer ---- */
      .site-footer {
        border-top: 1px solid var(--hair);
        margin-top: 72px;
        background: var(--paper);
      }
      .foot-inner {
        max-width: 880px;
        margin: 0 auto;
        padding: 40px 24px 32px;
        box-sizing: border-box;
      }
      .foot-top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
      }
      .foot-wordmark {
        font-size: 18px;
        font-weight: 600;
        color: var(--ink);
      }
      .foot-tag {
        font-size: 13px;
        color: var(--muted);
      }
      .foot-cols {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 24px;
      }
      .foot-h {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--faint);
        margin-bottom: 12px;
      }
      .foot-tools {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 20px;
      }
      .foot-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .foot-cols a {
        font-size: 13.5px;
        color: var(--ink-soft);
        text-decoration: none;
      }
      .foot-cols a:hover {
        color: var(--ink);
      }
      .foot-bottom {
        margin-top: 30px;
        padding-top: 18px;
        border-top: 1px solid var(--hair);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
        font-size: 12.5px;
        color: var(--faint);
      }

      @media (max-width: 720px) {
        .nav-desktop {
          display: none;
        }
        .hamburger {
          display: inline-flex;
        }
        .foot-cols {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>
  </body>
</html>
